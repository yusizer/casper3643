# === Casper testnet (casper:casper-test) ===
CAIP2_CHAIN_ID=casper:casper-test
RPC_URL=https://node.testnet.casper.network/rpc
CHAIN_NAME=casper-test

# === x402 facilitator ===
# Hosted (free tier 25/day): https://x402-facilitator.cspr.cloud  + CSPR_CLOUD_ACCESS_TOKEN
# Self-hosted: http://localhost:4022
FACILITATOR_URL=http://localhost:4022
FACILITATOR_API_KEY=
CSPR_CLOUD_ACCESS_TOKEN=

# === Payment asset (testnet WCSPR) ===
ASSET_PACKAGE=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
ASSET_NAME=Wrapped CSPR
ASSET_SYMBOL=WCSPR
ASSET_DECIMALS=9
ASSET_VERSION=1

# === Data-feed server (payee) ===
PAYEE_ADDRESS=00<64-hex-account-hash-of-the-data-feed-operator>
DATA_FEED_PORT=4021

# === Specialist agent keys (secp256k1 PEM, separate per agent for isolation) ===
AGENT_SANCTIONS_KEY=./keys/agent_sanctions/secret_key.pem
AGENT_VALUATION_KEY=./keys/agent_valuation/secret_key.pem
AGENT_LEGAL_KEY=./keys/agent_legal/secret_key.pem
AGENT_KEY_ALGO=secp256k1

# === LLM (specialist verdicts) ===
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# === On-chain attestation (deployed AttestationRegistry package hash) ===
ATTESTATION_REGISTRY_PACKAGE=hash-<deploy-and-fill>
ORCHESTRATOR_KEY=./keys/orchestrator/secret_key.pem

# === IPFS (reasoning trace) ===
IPFS_API_URL=
